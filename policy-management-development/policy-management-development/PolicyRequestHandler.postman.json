{
  "info": {
    "name": "Policy Management - Policy Request APIs",
    "_postman_id": "c2e7c7aa-4a22-policy-requests",
    "description": "Submission APIs for PolicyLifecycleWorkflow signals",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/v1" },
    { "key": "policyNumber", "value": "PLI/2023/123456" }
  ],
  "item": [

    {
      "name": "Surrender Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Idempotency-Key", "value": "{{uuid}}" }
        ],
        "url": "{{baseUrl}}/policies/{{policyNumber}}/requests/surrender",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_channel\": \"CUSTOMER_PORTAL\",\n  \"submitted_by\": 101,\n  \"payload\": {\n    \"disbursement_method\": \"NEFT\",\n    \"bank_account_id\": 5001,\n    \"reason\": \"Policy surrender\"\n  }\n}"
        }
      }
    },

    {
      "name": "Loan Request",
