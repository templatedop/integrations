{
  "info": {
    "_postman_id": "509d4db9-30b5-426e-90bb-4cfbe60aa02e",
    "name": "Revival Workflow API",
    "description": "Complete workflow for testing Policy Revival process with Temporal integration.\n\n## Workflow Sequence:\n1. **Index Revival Request** - Create request and start Temporal workflow\n2. **Data Entry** - Submit revival details and send signal to workflow\n3. **Quality Check** - Validate data and send signal\n4. **Approval** - Approve request, start SLA timer, send signal\n5. **First Collection** - Process dual payment, send signal, activate policy\n\n## Prerequisites:\n- Temporal server running on localhost:7233\n- PostgreSQL database with test data\n- API server running on localhost:8080\n- Test policy: 0000000000001 (eligible for revival)\n\n## Usage:\n1. Set environment variables (base_url, ticket_id)\n2. Run requests in sequence\n3. Check Temporal UI: http://localhost:8089\n4. Verify database updates",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "51561985",
    "_collection_link": "https://go.postman.co/collection/51561985-509d4db9-30b5-426e-90bb-4cfbe60aa02e?source=collection_link"
  },
  "item": [
    {
      "name": "1. Index Revival Request",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Clear any previous ticket_id before indexing",
              "pm.environment.unset('ticket_id');",
              "pm.environment.unset('workflow_id');",
              "console.log('Starting fresh revival request...');"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Validate response",
              "pm.test('Status code is 200 or 201', function () {",
              "    pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('Response has success status', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql('success');",
              "});",
              "",
              "pm.test('Response contains ticket_id', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('ticket_id');",
              "});",
              "",
              "pm.test('Workflow started successfully', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('workflow_id');",
              "});",
              "",
              "// Store ticket_id and workflow_id for subsequent requests",
              "const jsonData = pm.response.json();",
              "if (jsonData.data && jsonData.data.ticket_id) {",
              "    pm.environment.set('ticket_id', jsonData.data.ticket_id);",
              "    console.log('✅ Saved ticket_id:', jsonData.data.ticket_id);",
              "}",
              "if (jsonData.data && jsonData.data.workflow_id) {",
              "    pm.environment.set('workflow_id', jsonData.data.workflow_id);",
              "    console.log('✅ Saved workflow_id:', jsonData.data.workflow_id);",
              "}",
              "",
              "console.log('✅ Index Request completed:', jsonData);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"policy_number\": \"0000000000001\",\n  \"customer_id\": \"CUST0000000001\",\n  \"customer_name\": \"John Doe\",\n  \"request_date_time\": \"{{$isoTimestamp}}\",\n  \"request_owner\": \"BRANCH_USER_001\",\n  \"indexed_by\": \"POSTMAN_USER\",\n  \"office\": \"HEAD_OFFICE\",\n  \"revival_eligibility\": {\n    \"eligible\": true,\n    \"revival_count\": 0,\n    \"max_revivals_allowed\": 2,\n    \"max_installments\": 12\n  },\n  \"documents\": [\n    {\n      \"document_type\": \"REVIVAL_APPLICATION\",\n      \"document_id\": \"DOC001\"\n    },\n    {\n      \"document_type\": \"ID_PROOF\",\n      \"document_id\": \"DOC002\"\n    },\n    {\n      \"document_type\": \"ADDRESS_PROOF\",\n      \"document_id\": \"DOC003\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/v1/revival/requests/index",
          "host": [
            "{{base_url}}"
