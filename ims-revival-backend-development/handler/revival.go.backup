// IndexRevivalRequest creates a new revival request
func (h *RevivalHandler) IndexRevivalRequest(sctx *serverRoute.Context, req port.IndexRevivalRequest) (*port.IndexRequestResponse, error) {
	// Set request date time if not provided
	requestDateTime := req.RequestDateTime
	if requestDateTime.IsZero() {
		requestDateTime = time.Now()
	}

	// Validate policy using activity
	err := h.activities.ValidatePolicyActivity(sctx.Ctx, "", req.PolicyNumber)
	if err != nil {
		return &port.IndexRequestResponse{
			StatusCodeAndMessage: port.PolicyNotEligible,
			Data: port.IndexRequestData{
				Message: err.Error(),
			},
		}, nil
	}

	// Generate ticket ID
	ticketID, err := h.revivalRepo.GenerateTicketID(sctx.Ctx)
	if err != nil {
		return nil, fmt.Errorf("failed to generate ticket ID: %w", err)
	}

	// Create revival request
	revivalReq := domain.RevivalRequest{
		TicketID:      ticketID,
		PolicyNumber:  req.PolicyNumber,
		RequestType:   "INSTALLMENT_REVIVAL",
		CurrentStatus: "INDEXED",
		IndexedDate:   &requestDateTime,
		IndexedBy:     &req.IndexedBy,
		RequestOwner:  &req.RequestOwner,
	}

	createdRevival, err := h.revivalRepo.CreateRevivalRequest(sctx.Ctx, revivalReq)
	if err != nil {
		return nil, fmt.Errorf("failed to create revival request: %w", err)
	}

	return &port.IndexRequestResponse{
		StatusCodeAndMessage: port.CreateSuccess,
		Data: port.IndexRequestData{
			TicketID:        createdRevival.TicketID,
			Status:          createdRevival.CurrentStatus,
			RequestDateTime: *createdRevival.IndexedDate,
			Message:         "Revival request indexed successfully",
		},
	}, nil
}

// SubmitDataEntry submits data entry for indexed request
func (h *RevivalHandler) SubmitDataEntry(sctx *serverRoute.Context, req port.DataEntryRequest) (*port.DataEntryResponse, error) {
	// Check if revival request exists
	revivalReq, err := h.revivalRepo.GetRevivalRequestByTicketID(sctx.Ctx, req.TicketID)
	if err != nil {
		return nil, fmt.Errorf("revival request not found: %w", err)
	}

	// Check if request is in INDEXED status
	if revivalReq.CurrentStatus != "INDEXED" {
		return &port.DataEntryResponse{
			StatusCodeAndMessage: port.InvalidTicketStatus,
		}, nil
	}

	// Set data entry timestamp if not provided
	dataEntryTimestamp := req.DataEntryTimestamp
	if dataEntryTimestamp.IsZero() {
		dataEntryTimestamp = time.Now()
	}

	// Update revival request with data entry details
	err = h.revivalRepo.UpdateRevivalRequestForDataEntry(
		sctx.Ctx,
		req.TicketID,
		req.DataEnteredBy,
		req.RevivalDetails.Installments,
		req.RevivalDetails.RevivalAmount,
		req.RevivalDetails.InstallmentAmount,
	)
	if err != nil {
		return nil, fmt.Errorf("failed to update revival request for data entry: %w", err)
	}

	return &port.DataEntryResponse{
		StatusCodeAndMessage: port.UpdateSuccess,
		Data: port.DataEntryData{
			TicketID:           req.TicketID,
			Status:             "DATA_ENTRY_PENDING",
			Message:            "Data entry submitted successfully",
			DataEntryTimestamp: dataEntryTimestamp,
		},
	}, nil
}

// SubmitQualityCheck submits quality check for data entry
func (h *RevivalHandler) SubmitQualityCheck(sctx *serverRoute.Context, req port.QualityCheckRequest) (*port.QualityCheckResponse, error) {
	// Check if revival request exists
	revivalReq, err := h.revivalRepo.GetRevivalRequestByTicketID(sctx.Ctx, req.TicketID)
	if err != nil {
		return nil, fmt.Errorf("revival request not found: %w", err)
	}

	// Check if request is in DATA_ENTRY_PENDING status
	if revivalReq.CurrentStatus != "DATA_ENTRY_PENDING" {
		return &port.QualityCheckResponse{
			StatusCodeAndMessage: port.TicketNotReadyForQC,
		}, nil
	}

	// Set QC timestamp if not provided
	qcTimestamp := req.QCTimestamp
	if qcTimestamp.IsZero() {
		qcTimestamp = time.Now()
	}

	// Update revival request for QC
	err = h.revivalRepo.UpdateRevivalRequestForQC(sctx.Ctx, req.TicketID, req.QCPerformedBy, req.QCPassed)
	if err != nil {
		return nil, fmt.Errorf("failed to update revival request for QC: %w", err)
	}

	nextStatus := "APPROVAL_PENDING"
	if !req.QCPassed {
		nextStatus = "DATA_ENTRY_PENDING"
	}

	return &port.QualityCheckResponse{
		StatusCodeAndMessage: port.UpdateSuccess,
		Data: port.QualityCheckData{
			TicketID:         req.TicketID,
			Status:           nextStatus,
			Message:          "Quality check submitted successfully",
			QCTimestamp:      qcTimestamp,
			ValidationErrors: req.ValidationErrors,
		},
	}, nil
}

// ApproveRequest approves revival request
func (h *RevivalHandler) ApproveRequest(sctx *serverRoute.Context, req port.ApprovalRequest) (*port.ApprovalResponse, error) {
	// Check if revival request exists
	revivalReq, err := h.revivalRepo.GetRevivalRequestByTicketID(sctx.Ctx, req.TicketID)
	if err != nil {
		return nil, fmt.Errorf("revival request not found: %w", err)
	}

	// Check if request is in APPROVAL_PENDING status
	if revivalReq.CurrentStatus != "APPROVAL_PENDING" {
		return &port.ApprovalResponse{
			StatusCodeAndMessage: port.InvalidApprovalStatus,
		}, nil
	}

	// Set approval timestamp if not provided
	approvalTimestamp := req.ApprovalTimestamp
	if approvalTimestamp.IsZero() {
		approvalTimestamp = time.Now()
	}

	// Calculate SLA dates - 60 days from approval date
	slaStartDate := approvalTimestamp
	slaEndDate := approvalTimestamp.AddDate(0, 0, 60) // 60-day SLA (IR_11)

	// Update revival request for approval
	if req.Approve {
		err = h.revivalRepo.UpdateRevivalRequestForApproval(
			sctx.Ctx,
			req.TicketID,
			req.ApprovedBy,
			slaStartDate,
			slaEndDate,
		)
	} else {
		// Handle rejection
		// This is a rejection case, handled separately but here for completeness
		return &port.ApprovalResponse{
			StatusCodeAndMessage: port.InvalidApprovalStatus,
		}, nil
	}

	if err != nil {
		return nil, fmt.Errorf("failed to approve revival request: %w", err)
	}

	// Calculate remaining SLA days
	slaRemainingDays := 60
	if !slaEndDate.IsZero() {
		slaRemainingDays = int(slaEndDate.Sub(time.Now()).Hours() / 24)
		if slaRemainingDays < 0 {
			slaRemainingDays = 0
		}
	}

	return &port.ApprovalResponse{
		StatusCodeAndMessage: port.UpdateSuccess,
		Data: port.ApprovalData{
			TicketID:          req.TicketID,
			Status:            "APPROVED",
			Message:           "Revival request approved successfully",
			ApprovalTimestamp: approvalTimestamp,
			SLAEndDate:        slaEndDate,
			SLARemainingDays:  slaRemainingDays,
		},
	}, nil
}

